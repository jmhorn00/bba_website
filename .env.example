# ─── Django ────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────────────────────────────
# Postgres connection (matches the db service in docker-compose)
POSTGRES_DB=bbacpas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@db:5432/bbacpas

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Where contact form submissions and payment notifications are sent
CONTACT_EMAIL=info@bbacpas.com

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Test keys from https://dashboard.stripe.com/test/apikeys
# Switch to live keys (pk_live_... / sk_live_...) for production
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret from https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Wagtail ───────────────────────────────────────────────────────────────────
WAGTAIL_SITE_NAME=BBA CPAs
WAGTAILADMIN_BASE_URL=https://bbacpas.com

# ─── Cache ─────────────────────────────────────────────────────────────────────
# Seconds to cache the newsletter RSS feed (default 1 hour)
CACHE_TIMEOUT=3600
